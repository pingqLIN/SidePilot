{
  "name": "sidepilot-copilot-bridge",
  "version": "1.0.0",
  "description": "Lightweight HTTP bridge between SidePilot Chrome Extension and GitHub Copilot CLI SDK",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "dev": "tsx watch src/server.ts",
    "dev:supervisor": "tsx watch src/supervisor.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "npm run build && node dist/supervisor.js",
    "start:worker": "node dist/server.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@github/copilot-sdk": "^0.1.8",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.6",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
