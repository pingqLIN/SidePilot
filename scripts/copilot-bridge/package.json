{
  "name": "sidepilot-copilot-bridge",
  "version": "1.0.0",
  "description": "Lightweight HTTP bridge between SidePilot Chrome Extension and GitHub Copilot CLI SDK",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:supervisor": "tsx watch src/supervisor.ts",
    "build": "tsc",
    "start": "node dist/supervisor.js",
    "start:worker": "node dist/server.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@github/copilot-sdk": "^0.1.8",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.6",
    "rimraf": "^6.1.2",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
